#!/bin/sh
# Re-exec with zsh (required)
if [ -z "$ZSH_VERSION" ]; then
  command -v zsh >/dev/null || { echo "[error] zsh required"; exit 1; }
  exec zsh "$0" "$@"
fi

if [[ ! -d .git ]]; then
  git init
  print -P "%F{green}[ok]%f    git init"
fi

print -P "%F{blue}[info]%f  Open Claude and describe what you want to build — it will create CLAUDE.md for you."
